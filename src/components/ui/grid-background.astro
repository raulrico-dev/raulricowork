---
// HeroBackground.astro
// Drop this component anywhere in your Astro layout
---

<div id="hero-background" class="absolute inset-0 w-full h-full overflow-hidden bg-black cursor-crosshair">
    <canvas id="grid-canvas"></canvas>
  </div>
  
  <style>
    #grid-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
    }
  </style>
  
  <script>
    // ─── Colors ───────────────────────────────────────────────────────────────
    const COLORS = {
      background: "#ffffff",
      gridLines: "rgba(216,231,255,0.98)",
  
      cellFill: "rgba(246,249,255,",       // opacity appended at runtime
      cellStroke: "rgba(100,180,255,",    // opacity appended at runtime
      cellFillOpacity: 0.98,
      cellStrokeOpacity: 0.0,
  
      glow: {
        inner: "rgba(255,201,243,0.25)",
        mid:   "rgba(255,201,243,0.16)",
        outer: "rgba(230,222,233,0)",
      },
    } as const;
    // ─────────────────────────────────────────────────────────────────────────
  
    const CELL = 46;
    const FADE = 0.93; // fade speed per frame: lower = faster, higher = longer trail
  
    const GLOW_CENTER_X = 0.5;  // 0–1 relative to canvas width
    const GLOW_CENTER_Y = 0.38; // 0–1 relative to canvas height
    const GLOW_RADIUS   = 0.6;  // relative to Math.min(width, height)
  
    type Cell = { col: number; row: number; op: number };
  
    const hero   = document.getElementById("hero-background") as HTMLElement;
    const canvas = document.getElementById("grid-canvas") as HTMLCanvasElement;
    const ctx    = canvas.getContext("2d")!;
    const cells: Record<string, Cell> = {};
  
    function resize() {
      canvas.width  = hero.offsetWidth;
      canvas.height = hero.offsetHeight;
    }
  
    resize();
    window.addEventListener("resize", resize);
  
    hero.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      const col  = Math.floor((e.clientX - rect.left) / CELL);
      const row  = Math.floor((e.clientY - rect.top)  / CELL);
      const key  = `${col},${row}`;
      cells[key] = { col, row, op: 1.0 };
    });
  
    function drawRadialGlow(w: number, h: number) {
      const cx  = w * GLOW_CENTER_X;
      const cy  = h * GLOW_CENTER_Y;
      const r   = Math.min(w, h) * GLOW_RADIUS;
      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
      grd.addColorStop(0,   COLORS.glow.inner);
      grd.addColorStop(0.5, COLORS.glow.mid);
      grd.addColorStop(1,   COLORS.glow.outer);
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, w, h);
    }
  
    function loop() {
      const w = canvas.width;
      const h = canvas.height;
  
      ctx.clearRect(0, 0, w, h);
  
      ctx.fillStyle = COLORS.background;
      ctx.fillRect(0, 0, w, h);
  
      for (const key in cells) {
        const c = cells[key];
  
        if (c.op > 0.01) {
          const x = c.col * CELL;
          const y = c.row * CELL;
  
          ctx.fillStyle = `${COLORS.cellFill}${c.op * COLORS.cellFillOpacity})`;
          ctx.fillRect(x + 0.5, y + 0.5, CELL - 1, CELL - 1);
  
          ctx.strokeStyle = `${COLORS.cellStroke}${c.op * COLORS.cellStrokeOpacity})`;
          ctx.lineWidth = 0.5;
          ctx.strokeRect(x + 0.5, y + 0.5, CELL - 1, CELL - 1);
  
          c.op *= FADE;
        } else {
          delete cells[key];
        }
      }
  
      const cols = Math.ceil(w / CELL) + 1;
      const rows = Math.ceil(h / CELL) + 1;
  
      ctx.strokeStyle = COLORS.gridLines;
      ctx.lineWidth = 0.25;
  
      for (let c = 0; c <= cols; c++) {
        ctx.beginPath();
        ctx.moveTo(c * CELL, 0);
        ctx.lineTo(c * CELL, h);
        ctx.stroke();
      }
  
      for (let r = 0; r <= rows; r++) {
        ctx.beginPath();
        ctx.moveTo(0, r * CELL);
        ctx.lineTo(w, r * CELL);
        ctx.stroke();
      }
  
      drawRadialGlow(w, h);
  
      requestAnimationFrame(loop);
    }
  
    loop();
  </script>
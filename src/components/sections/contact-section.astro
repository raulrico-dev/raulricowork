---
import { MY_EMAIL } from "@/lib/constants/my_data";


---

<article class="py-24 px-6 max-w-7xl mx-auto">
  <div
    class="relative overflow-hidden rounded-2xl border border-indigo-100 bg-gradient-to-br from-indigo-50 via-white to-indigo-50 p-10 md:p-16"
  >
    <!-- Subtle background glow -->
    <div
      class="absolute -top-24 -right-24 w-72 h-72 bg-indigo-200/40 blur-3xl rounded-full"
    >
    </div>
    <div
      class="absolute -bottom-24 -left-24 w-72 h-72 bg-purple-200/40 blur-3xl rounded-full"
    >
    </div>

    <div
      class="relative flex flex-col items-center text-center max-w-2xl mx-auto"
    >
      <div class="mx-auto mb-8">
        <!-- Label -->
        <span
          class="text-xs font-semibold tracking-widest text-slate-400 uppercase mb-4"
        >
          Contact
        </span>

        <!-- Headline -->
        <h2
          class="text-3xl md:text-4xl font-bold text-indigo-950 font-dm mb-4 leading-tight"
        >
          Building a platform or internal system?
        </h2>

        <!-- Subtext -->
        <p class="text-slate-600 text-pretty mb-4">
          I help design and develop scalable web platforms, dashboards, and
          systems ready for real-world use.
        </p>

        <!-- Micro trust line -->
        <p class="text-sm text-slate-500">
          Taking on a limited number of projects this quarter
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <!-- Primary -->
        <a
          href="#contact"
          class="rounded-full h-12 px-8 inline-flex items-center justify-center text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 transition-colors duration-200 shadow-md"
        >
          Start a project
        </a>

        <!-- Secondary -->
        <a
          href="#projects"
          class="text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors duration-200"
        >
          View projects →
        </a>
      </div>

      <!-- email fallback -->
      <p class="text-xs text-slate-400 mt-4">
        Or reach out directly at <a
          href={`mailto:${MY_EMAIL}`}
          class="text-indigo-600">{MY_EMAIL}</a
        >
      </p>
    </div>
  </div>
</article>

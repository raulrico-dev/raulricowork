---
const metrics = [

  {
    id: 1,
    title: "20+ Projects Built",
    description: "Full-stack applications from idea to production",
  },
  {
    id: 2,
    title: "Live Systems",
    description: "Handling real users, data, and operations",
  },
  {
    id: 3,
    title: "Scalable Architecture",
    description: "Designed for performance and growth",
  },
  {
    id: 4,
    title: "End-to-End Development",
    description: "From UI to backend infrastructure",
  },
];
---

<section
    aria-label="Key metrics"
    class="relative w-full max-w-7xl m-auto px-6 pb-20"
>
    <div class="mx-auto w-full">
            <ul class="grid grid-cols-2 lg:grid-cols-4 gap-6 divide-y divide-white/10 md:divide-y-0 md:divide-x">
                {
                    metrics.map((metric) => (
                        <li class="p-6 md:p-8 relative first:lg:[&>span]:hidden">
                            <span class="h-full w-0.5 bg-slate-100 absolute left-0 block"></span>
                            <div class="mt-4">
                                <div class="text-2xl font-dm font-semibold tracking-wide text-indigo-950">
                                    {metric.title}
                                </div>
                                <div class="mt-0 text-sm leading-relaxed text-slate-400">
                                    {metric.description}
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
    </div>
</section>

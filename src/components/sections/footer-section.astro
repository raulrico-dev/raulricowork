---
// TODO: Add social media links and update the email
import { MY_DESCRIPTION, MY_EMAIL, MY_LOCATION, MY_NAME } from "@/lib/constants/my_data";
---

<footer class="mt-24 border-t border-indigo-100">
    <div class="max-w-7xl mx-auto px-6 py-16">
  
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
  
        <!-- Brand / Identity -->
        <div class="flex flex-col gap-4 max-w-sm">
          <h3 class="text-lg font-semibold font-dm text-indigo-950">
            {MY_NAME}
          </h3>
  
          <p class="text-sm text-slate-600 leading-relaxed">
            {MY_DESCRIPTION}
          </p>
  
          <p class="text-xs text-slate-400">
            Based in {MY_LOCATION} · Available for selected projects
          </p>
        </div>
  
        <!-- Navigation -->
        <div class="flex flex-col gap-4">
          <h4 class="text-sm font-semibold text-indigo-950 uppercase tracking-widest">
            Navigation
          </h4>
  
          <ul class="flex flex-col gap-2 text-sm text-slate-600">
            <li>
              <a href="#projects" class="hover:text-indigo-600 transition-colors">
                Projects
              </a>
            </li>
            <li>
              <a href="#about" class="hover:text-indigo-600 transition-colors">
                About
              </a>
            </li>
            <li>
              <a href="#contact" class="hover:text-indigo-600 transition-colors">
                Contact
              </a>
            </li>
          </ul>
        </div>
  
        <!-- Contact -->
        <div class="flex flex-col gap-4">
          <h4 class="text-sm font-semibold text-indigo-950 uppercase tracking-widest">
            Contact
          </h4>
  
          <ul class="flex flex-col gap-2 text-sm text-slate-600">
            <li>
              <a href={`mailto:${MY_EMAIL}`} class="hover:text-indigo-600 transition-colors">
                {MY_EMAIL}
              </a>
            </li>
            <!-- <li>
              <a href="https://linkedin.com" target="_blank" class="hover:text-indigo-600 transition-colors">
                LinkedIn
              </a>
            </li> -->
            <!-- <li>
              <a href="https://github.com" target="_blank" class="hover:text-indigo-600 transition-colors">
                GitHub
              </a>
            </li> -->
          </ul>
        </div>
  
      </div>
  
      <!-- Bottom bar -->
      <div class="mt-16 pt-6 border-t border-indigo-100 flex flex-col md:flex-row items-center justify-between gap-4">
  
        <p class="text-xs text-slate-400">
          &#xa9; {new Date().getFullYear()} {MY_NAME}. All rights reserved.
        </p>
  
        <p class="text-xs text-slate-400">
          Built with Astro · Tailwind
        </p>
  
      </div>
  
    </div>
  </footer>
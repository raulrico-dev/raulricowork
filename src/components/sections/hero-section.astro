---
import GridBackground from "@/components/ui/grid-background.astro";
---

<section id="top" class="relative w-full h-screen flex flex-col">
    <GridBackground />

    <div
        class="relative w-full max-w-7xl min-h-max m-auto flex flex-col items-center justify-center px-6 py-16"
    >
        <div class="mx-auto flex flex-col items-center justify-center">
            <span
                class="inline-flex items-center justify-center gap-2 text-sm font-normal text-center font-dm text-slate-900 bg-white/50 border border-indigo-100 drop-shadow-[0_8px_4px] drop-shadow-indigo-200/25 backdrop-blur-sm px-4 py-2 rounded-full"
            >
                Digital Systems
                <div class="w-1 h-1 bg-slate-600 rounded-full"></div>
                Dashboards
                <div class="w-1 h-1 bg-slate-600 rounded-full"></div>
                Websites
            </span>
            <div class="mt-4 flex flex-col items-center justify-center gap-2">
                <p
                    class="text-center text-indigo-950 text-[clamp(2rem,6vw,3.5rem)] font-semibold leading-[1.05] tracking-[1.05] font-dm"
                >
                    <span class="block">I build digital systems</span>
                    <span class="block"
                        >for <span class="text-indigo-600">
                            modern brands
                        </span>
                    </span>
                </p>
                <p
                    class="text-center text-slate-500 text-[clamp(1.15rem,4vw,1.25rem)] font-medium leading-tight tracking-[1.05]"
                >
                    Built for performance, scalability, and real-world use
                </p>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-2 mt-8 w-full max-w-[460px] mx-auto">
                <a
                    href="#portfolio"
                    class="flex-1 shrink-0 rounded-full h-12 p-px bg-linear-36 from-violet-500 to-sky-500"
                >
                    <div
                        class="w-full h-full min-w-max px-4 py-3 inline-flex items-center justify-center space-x-2 rounded-full text-white bg-indigo-600/80 hover:bg-indigo-600 transition-colors duration-200"
                    >
                        <span class="text-sm font-semibold tracking-wider font-dm">See Projects</span>
                    </div>
                </a>
                
                <a
                    href="#contact"
                    class="flex-1 shrink-0 rounded-full h-12 p-px bg-linear-36 from-indigo-500 to-cyan-500"
                >
                    <div
                        class="w-full h-full min-w-max px-4 py-3 inline-flex items-center justify-center space-x-2 rounded-full text-indigo-950 hover:text-indigo-700 bg-white transition-colors duration-200"
                    >
                        <span class="text-sm font-semibold tracking-wider font-dm">Available for projects</span>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
                          </svg>
                    </div>
                </a>

            </div>
        </div>
    </div>
</section>

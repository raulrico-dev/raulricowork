---
type Projects = {
    id: string | number,
    name: string,
    description: string,
    cover_url: string,
    tags: string[],
    images: [
        { url: string, alt: string }
    ],
    external_url: string
}
const projects = [
    {
        id: "ceducap",
        name: "Ceducap",
        description: "",
        tags: [
            "Landing",
            "Dashboard",
            "BlockChain",
            "Supabase",
        ],
        cover_url: "",
        images: [],
        external_url: "https://ceducap.mx"
    },
    {
        id: "raulricomusic",
        name: "Raul Rico",
        description: "",
        tags: [
            "Landing",
        ],
        cover_url: "",
        images: [],
        external_url: "https://raulricomusic.com"
    },
    {
        id: "gb-properties",
        name: "GB Properties",
        description: "",
        tags: [
            "Landing",
            "Dashboard",
            "BlockChain",
            "Firebase",
        ],
        cover_url: "",
        images: [],
        external_url: "https://gbproperties.io"
    },
    {
        id: "dmsnrecords",
        name: "DMSN Records",
        description: "",
        tags: [
            "Landing",
            "Dashboard",
            "Supabase",
        ],
        cover_url: "",
        images: [],
        external_url: "https://dmsnrecords.com"
    },
]
---

<article class="py-24 px-6 max-w-5xl mx-auto">

    <header class="mb-16">
      <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase mb-3">Selected Work</p>
      <h2 class="text-3xl font-bold text-gray-900">Top Projects</h2>
    </header>
  
    <section>
      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-4">
  
        {projects.map((item) => (
          <li class="group block">

              <!-- Cover -->
              <div class="relative w-full aspect-9/6 bg-gray-100 overflow-hidden">
                {item.cover_url
                  ? <img src={item.cover_url} alt={item.name} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out" />
                  : <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-purple-50" />
                }
                <!-- Subtle dark overlay on hover -->
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300" />
                <!-- External link icon -->
                <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  
                  <!-- external link -->
                  <a href={item.external_url} target="_blank" rel="noopener noreferrer" 
                  class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-white text-gray-900">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>

                </div>
              </div>
  
              <!-- Content -->
              <div class="pt-3 pb-8 flex flex-col gap-2">
                <div>
                  <h3 class="text-sm font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors duration-200">{item.name}</h3>
                  {item.description && (
                    <p class="text-sm text-gray-400 mt-0.5 line-clamp-1">{item.description}</p>
                  )}
                </div>
                <div class="flex flex-wrap gap-1 shrink-0 mt-0.5">
                  {item.tags.map((tag) => (
                    <span key={tag} class="text-xs text-gray-400 border border-gray-200 px-2 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

          </li>
        ))}
  
      </ul>
    </section>
  
  </article>
  